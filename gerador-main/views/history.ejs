<%- include('partials/head', { title: 'Histórico' }) %>
<%- include('partials/header') %>
<div class="container">
  <%- include('partials/sidebar') %>
  <main>
    <div class="page-header">
      <div>
        <p class="eyebrow">auditoria</p>
        <h1>Histórico</h1>
      </div>
    </div>

    <section class="panel">
      <div class="table-wrap">
        <table>
          <thead>
            <tr><th>Código</th><th>Usuário</th><th>Origem</th><th>Data</th></tr>
          </thead>
          <tbody>
            <% if (!history.length) { %>
              <tr><td colspan="4">Nenhum histórico ainda.</td></tr>
            <% } %>
            <% history.forEach(item => { %>
              <tr>
                <td><code><%= item.code || '-' %></code></td>
                <td><%= item.username %></td>
                <td><%= item.origin %></td>
                <td><%= item.created_at %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </section>
  </main>
</div>
<%- include('partials/footer') %>
