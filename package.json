{
  "name": "code-manager-saas",
  "version": "1.1.0",
  "description": "Aplicação SaaS de gerenciamento e automação de códigos",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "init-db": "node scripts/init-db.js",
    "check": "node --check server.js && node --check controllers/automationController.js && node --check utils/automationRunner.js",
    "install-browser": "npx playwright install chromium"
  },
  "dependencies": {
    "bcrypt": "^5.1.0",
    "better-sqlite3": "^9.0.0",
    "compression": "^1.7.4",
    "dotenv": "^16.0.3",
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "express-rate-limit": "^6.7.0",
    "express-session": "^1.17.3",
    "helmet": "^7.0.0",
    "playwright": "^1.49.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "engines": {
    "node": "20.x"
  }
}
