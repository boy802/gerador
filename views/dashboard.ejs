<%- include('layout', { body: `
<h1>Dashboard</h1>
<div class="cards">
  <div class="card">Total de códigos: <%= stats.total %></div>
  <div class="card">Disponíveis: <%= stats.available %></div>
  <div class="card">Usados: <%= stats.used %></div>
  <div class="card">Entregues hoje: <%= stats.today %></div>
  <div class="card">Total de lotes: <%= stats.batches %></div>
</div>

<h2>Últimos códigos utilizados</h2>
<table>
  <thead>
    <tr><th>Código</th><th>Data</th></tr>
  </thead>
  <tbody>
    <% stats.lastUsed.forEach(item => { %>
      <tr>
        <td><%= item.code %></td>
        <td><%= item.created_at %></td>
      </tr>
    <% }) %>
  </tbody>
</table>
` }) %>
